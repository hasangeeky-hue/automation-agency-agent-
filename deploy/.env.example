# Copy to deploy/.env and fill in. NEVER commit the real .env.

# --- Postgres ---
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# --- Model APIs ---
ANTHROPIC_API_KEY=sk-ant-...    # the ONLY model key needed (Claude-only setup)

# --- Engine behaviour ---
MEASURE_AFTER_DAYS=7            # days a piece collects traffic before measurement
PER_JOB_BUDGET_USD=0.50        # cost cap per job (halts the job if exceeded)
PER_DAY_BUDGET_USD=50          # org-wide daily cost cap
USE_FIXTURES=0                 # 1 = dev mode, no real API calls (needs recorded fixtures)

# STORE and DATABASE_URL are set in docker-compose.yml (STORE=pg, db service).

# ===========================================================================
# CONNECTORS ("the hands") — fill in the ones you have; blank = stays offline.
# Each block you complete turns another gap into a live capability. The engine
# runs fine with all of these blank (safe offline defaults).
# ===========================================================================

# --- WordPress publishing (Q2/Q5/Q8) ---
# In wp-admin: Users -> Profile -> Application Passwords -> add "Content Engine".
WORDPRESS_URL=                 # e.g. https://anthropos-automation.com
WORDPRESS_USER=                # your WP username
WORDPRESS_APP_PASSWORD=        # the generated application password (has spaces)
WP_STATUS=draft                # draft = stage for review (safe). Set to: publish

# --- Email sending (Q17/Q18) ---
SMTP_HOST=                     # e.g. smtp.gmail.com  (use an App Password, not your login)
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                     # the From address (defaults to SMTP_USER)
SMTP_STARTTLS=1                # 1 for port 587; port 465 uses SSL automatically

# --- Web search + lead sourcing (Q10/Q13) ---
SEARCH_PROVIDER=               # tavily | serpapi
SEARCH_API_KEY=

# --- LinkedIn leads (Q14) — via a COMPLIANT people-data provider, NOT scraping ---
LINKEDIN_PROVIDER_URL=         # your provider's people-search endpoint
LINKEDIN_API_KEY=

# --- Google Search Console + GA4 (Q7 SEO data, Q11 tracking) ---
GOOGLE_ACCESS_TOKEN=           # OAuth/service-account bearer token (read-only scopes)
GSC_SITE_URL=                  # e.g. https://anthropos-automation.com/
GA4_PROPERTY_ID=               # numeric GA4 property id

# --- Ads + backlinks (optional; easiest to feed as JSON from n8n) ---
ADS_JSON=                      # paste a Google/Meta Ads report as JSON, or leave blank
BACKLINKS_JSON=                # paste {client, competitors} referring-domain JSON
